# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local asset folders (not part of the build)
InsightScreenshot/
Logos/
Business Logos/
Servia Consulting HomePage_files/

# stray root-level assets (leading slash = root only, does not affect public/)
/*.png
/*.jpg
/*.jpeg
/*.docx
/*.pdf
